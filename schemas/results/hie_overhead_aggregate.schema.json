    "estimator": {
      "type": "string"
    },
    "maximum_increment": {
      "pattern": "^-?(?:\\d+(?:\\.\\d+)?|\\.\\d+)$",
      "type": "string"
    },
    "mean_increment": {
      "pattern": "^-?(?:\\d+(?:\\.\\d+)?|\\.\\d+)$",
