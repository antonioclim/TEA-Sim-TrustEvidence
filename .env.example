# TrustEvidence v2.0.0 external-service configuration template.
# Copy to .env before Docker-backed smoke tests or external benchmark run measurements.
# Defaults are execution conveniences, not measured evidence.
COMPOSE_PROFILES=baselines,fabric,harness
HAPI_IMAGE=hapiproject/hapi:latest
FABRIC_TOOLS_IMAGE=hyperledger/fabric-tools:2.5.16
FABRIC_VERSION=2.5.16
TRILLIAN_REF=v1.7.3
REKOR_REF=main
FABRIC_SAMPLES_REF=main
HAPI_BASE_URL=http://localhost:8080/fhir
REKOR_BASE_URL=http://localhost:3000
TRILLIAN_ENDPOINT=localhost:8090
TE_POSTGRES_DSN=postgresql://te:te@localhost:5434/trustevidence
