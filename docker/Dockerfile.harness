FROM python:3.12-slim
WORKDIR /work
COPY pyproject.toml README.md LICENSE ./
COPY src ./src
COPY data ./data
COPY docker-compose.full.yml ./docker-compose.full.yml
RUN pip install --no-cache-dir -e .[test,external]
ENV PYTHONPATH=/work/src
CMD ["python", "-m", "trustevidence.harness.smoke", "--dry-run"]
